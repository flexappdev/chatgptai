# Supabase — from ~/context-2026/agents/.env (sync via /abc-supabase chatgptai env sync)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter — single provider, picker selects model per chat
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# OG / referer headers OpenRouter wants
APP_URL=http://localhost:17002

# Optional
NEXT_PUBLIC_GA_ID=
BRAVE_API_KEY=
